# Copy this file to .env and fill in real values. .env is gitignored; this
# template is not.

# NVIDIA NIM. Used for BOTH the solver and the saboteur (different models,
# see config.yaml providers.solver_model / providers.saboteur_model).
NVIDIA_API_KEY=

# Anthropic. Used for the judge / triage role.
ANTHROPIC_API_KEY=

# Adapt Labs. Only needed for the optional Stage E finisher (see
# docs/ADAPTIVE_DATA.md). Not used by generate or eval-batch.
#ADAPTION_API_KEY=
